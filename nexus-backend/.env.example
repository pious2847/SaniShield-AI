# N.E.X.U.S. Backend — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Authentication
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Google Gemini AI (Free Tier — gemini-1.5-flash)
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS + Socket.io)
FRONTEND_URL=http://localhost:3000

# Africa's Talking SMS (optional — free sandbox available)
# Sign up at: https://africastalking.com
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=NEXUS

# Open-Meteo weather API — NO KEY REQUIRED (free & open)
